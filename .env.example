# The URL your WebView shell will load.
# Set this before running `npx cap sync android`.
#
# Examples:
#   Local dev (Android emulator → host machine):
#     WEBVIEW_URL=http://10.0.2.2:3000
#   Local dev (real device on same LAN):
#     WEBVIEW_URL=http://192.168.1.100:3000
#   Production:
#     WEBVIEW_URL=https://your-app.com
#
# If unset, the shell loads the local www/index.html fallback page.
WEBVIEW_URL=
